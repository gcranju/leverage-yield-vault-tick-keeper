# Funded EVM private key on Sonic. Pays gas for tick() and bears the (small) leverage-rebalance MEV.
# Use a fresh hot key — should hold ~10–50 S for fees, no other assets.
PRIVATE_KEY=0x...

# Sonic hub RPC. Public default works but rate-limits aggressively in production.
SONIC_RPC=https://rpc.soniclabs.com

# Sodax solver API. Used to POST tick tx hashes when a Leveraged intent is created.
# - Production: https://api.sodax.com
# - Staging:    https://api.sodax-staging.com
SOLVER_API_URL=https://api.sodax.com

# Optional: comma-separated list of vault addresses to manage. When unset, falls back to
# the built-in registry in src/config.ts. Use this for testnet vaults or a temporary
# allow-list without a code change.
# VAULTS=0xVault1,0xVault2

# Optional: max ms to wait per vault before timing out the tick tx. Default 60_000.
# TICK_TIMEOUT_MS=60000

# Optional: read-only mode. When set to 1/true/yes, the keeper assesses every vault and logs
# whether a tick *would* fire, but never sends a transaction. Use for a safe first run.
# DRY_RUN=1
